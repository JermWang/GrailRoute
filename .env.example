# Optional ERC-721 contract used to read each connected wallet's tokenized-card balance.
# Only read while the wallet is on Robinhood Chain; balances are never read from
# another network.
NEXT_PUBLIC_GRAILROUTE_ASSET_CONTRACT=

# Canonical public origin for metadata, Open Graph images, robots.txt, and
# sitemap.xml. Vercel supplies VERCEL_PROJECT_PRODUCTION_URL automatically, so
# this is only needed for a custom domain or a non-Vercel host.
NEXT_PUBLIC_SITE_URL=
