{
  // Cloudflare Workers sources only.
  //
  // @cloudflare/workers-types redeclares DOM globals (Request, Response, fetch,
  // caches, Event, …). Pulling it into the Next.js app config made those
  // conflicts real and left skipLibCheck as the only thing hiding them, so the
  // Workers types are scoped to the Workers code here instead.
  //
  // Check with: npx tsc -p tsconfig.cloudflare.json --noEmit
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "types": ["@cloudflare/workers-types", "node"],
    "lib": ["esnext"],
    "noEmit": true
  },
  "include": ["worker/**/*.ts", "db/**/*.ts", "examples/**/*.ts"],
  "exclude": ["node_modules"]
}
